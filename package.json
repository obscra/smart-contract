{
  "name": "obscra-contracts",
  "version": "0.1.0",
  "description": "OBSCRA — decentralized data marketplace and auction protocol on Solana",
  "license": "MIT",
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write 'app/**/*.{ts,tsx}' 'tests/**/*.ts' 'scripts/**/*.ts'",
    "build": "anchor build",
    "test": "anchor test --skip-local-validator",
    "test:local": "anchor test",
    "deploy:devnet": "ts-node scripts/deploy.ts --cluster devnet",
    "deploy:mainnet": "ts-node scripts/deploy.ts --cluster mainnet-beta",
    "airdrop": "ts-node scripts/airdrop.ts",
    "seed": "ts-node scripts/seed.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.0",
    "bs58": "^5.0.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.12",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "chai": "^4.4.1",
    "mocha": "^10.3.0",
    "prettier": "^3.2.5",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
