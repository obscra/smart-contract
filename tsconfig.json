{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "sourceMap": true,
    "types": ["mocha", "chai", "node"]
  },
  "include": [
    "tests/**/*",
    "app/**/*",
    "scripts/**/*",
    "indexer/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
